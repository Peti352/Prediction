# The Odds API key (ingyenes regisztráció: https://the-odds-api.com/)
# Másold le ezt a fájlt .env néven: cp .env.example .env
# Majd írd be a saját kulcsodat:
ODDS_API_KEY=your_key_here

# Telegram Bot (opcionális - a bot funkcióhoz kell)
# 1. Beszélj a @BotFather-rel a Telegramon, /newbot parancs
# 2. Másold ide a kapott tokent:
TELEGRAM_BOT_TOKEN=your_bot_token_here
# 3. Chat ID: írd a botnak, majd https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here
